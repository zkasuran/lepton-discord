# ── Discord ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=

# ── Anthropic (real /ask answers) ────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Agent wallet — the PAYER ─────────────────────────────────────────────
# Holds testnet USDC and signs EIP-3009 authorizations. With EIP-3009 the
# payer needs USDC only, no native gas (the facilitator pays gas).
# Generate a fresh key, fund it with testnet USDC, keep it OUT of git.
AGENT_PRIVATE_KEY=

# ── Service wallet — the SELLER (payTo) + facilitator/relayer ────────────
# Receives USDC and submits transferWithAuthorization on-chain (pays gas).
# SELLER_WALLET_ADDRESS is public; the facilitator key must stay secret.
SELLER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
FACILITATOR_PRIVATE_KEY=

# ── Optional: Circle developer-controlled wallet (alt agent signer) ──────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=

# ── Arc testnet / x402 ───────────────────────────────────────────────────
ARC_NETWORK=eip155:5042002
ARC_RPC_URL=https://rpc.testnet.arc.network
FACILITATOR_URL=https://gateway-api-testnet.circle.com
DEFAULT_PRICE_ATOMIC=10000

# ── API server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8402
API_BASE_URL=http://localhost:8402

# ── Storage ──────────────────────────────────────────────────────────────
DB_PATH=nanopay.db
